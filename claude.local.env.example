# Copy this file to claude.local.env and fill in your values.
#   cp claude.local.env.example claude.local.env

# Proxy (required if behind a proxy)
# On WSL2, claude.sh auto-replaces 127.0.0.1 with the Windows host gateway IP,
# so you can keep 127.0.0.1 here even on WSL2.
http_proxy=http://127.0.0.1:7897
https_proxy=http://127.0.0.1:7897
